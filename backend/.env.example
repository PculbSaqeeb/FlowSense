# FlowSense Backend Environment Variables
# Copy this file to .env and update values

# Application
APP_NAME=FlowSense API
APP_VERSION=1.0.0
ENVIRONMENT=development

# Database
# SQLite (default - zero config)
DATABASE_URL=sqlite+aiosqlite:///./flowsense.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flowsense

# API Configuration
API_V1_PREFIX=/api/v1
# Add your frontend URL(s) here
CORS_ORIGINS=["*"]
# Production example:
# CORS_ORIGINS=["https://flowsense.vercel.app","https://your-domain.com"]
